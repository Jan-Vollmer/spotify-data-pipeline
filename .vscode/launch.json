{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Spotify Pipeline",
      "type": "debugpy",
      "request": "launch",
      "module": "spotify_data_pipeline.main",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Attach to Python Functions",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 9091
      },
      "preLaunchTask": "func: host start"
    }
  ]
}